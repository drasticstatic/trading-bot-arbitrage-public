# Required — Arbitrum RPC access
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Required for manual/auto trading modes — wallet that owns the deployed contract
PRIVATE_KEY=your_metamask_private_key_here

# Required after contract deployment — set this to the deployed Arbitrage contract address
# Run: npx hardhat run scripts/deploy.js --network arbitrum  (then paste address here)
ARBITRAGE_ADDRESS=

# Required for local Hardhat fork testing — can use a Hardhat test account private key
HARDHAT_PRIVATE_KEY=your_hardhat_account_private_key_here

# Optional — custom Arbitrum RPC URL (overrides Alchemy default)
ARBITRUM_RPC_URL=

# Recommended — bearer token for REST API authentication
# If unset, only localhost requests are allowed (M6 safety)
BOT_API_TOKEN=

# Optional — CORS origin for dashboard access (default: http://localhost:5050)
CORS_ORIGIN=

# Optional — server port (default: 5050)
PORT=5050

# Optional — pin Hardhat fork to a specific block number (local mode only)
FORK_BLOCK_NUMBER=

# Optional — set to 0 to disable local evm_mine block advancement
AUTO_MINE_LOCAL_BLOCKS=1

# Optional — set to 1 for detailed spread logging in console
VERBOSE_SPREAD_LOGS=0
